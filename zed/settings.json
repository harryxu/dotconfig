// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "collaboration_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "agent_buffer_font_size": 21.0,
  "agent_ui_font_size": 21.0,
  "theme": "macOS Classic Light",
  "ssh_connections": [
    {
      "host": "192.168.19.233",
      "username": "harry",
      "args": [],
      "projects": [
        {
          "paths": ["/home/harry"],
        },
      ],
    },
  ],
  "edit_predictions": {
    "provider": "zed",
  },
  "icon_theme": "Material Icon Theme",
  "outline_panel": {
    "dock": "right",
  },
  "agent": {
    "dock": "right",
    "tool_permissions": {
      "tools": {
        "terminal": {
          "default": "allow"
        }
      }
    },
    "default_model": {
      "effort": "high",
      "enable_thinking": true,
      "provider": "zed.dev",
      "model": "claude-sonnet-4-6",
    },
  },
  "ui_font_size": 21.0,
  "ui_font_family": "Inter",
  "buffer_font_size": 25,
  "buffer_font_family": "Iosevka Nerd Font",
  "format_on_save": "off",
  "soft_wrap": "editor_width",
  "project_panel": {
    "dock": "left",
    "auto_reveal_entries": false,
    "hide_hidden": false,
    "hide_gitignore": false,
  },
  "file_scan_inclusions": ["node_modules", "**/node_modules"],
  "languages": {
    "JSON": { "format_on_save": "on" },
  },
  "git": {
    "inline_blame": {
      "enabled": false,
    },
  },

  "vim_mode": true,
  "vim": {
    "use_system_clipboard": "never",
  },

  "auto_install_extensions": {
    "catppuccin-icons": true,
    "dockerfile": true,
    "emmet": true,
    "fish": true,
    "git-firefly": true,
    "html": true,
    "java": true,
    "log": true,
    "lua": true,
    "macos-classic": true,
    "material-icon-theme": true,
    "alabaster": true,
    "ini": true,
    "toml": true,
    "catppuccin": true,
    "nvim-nightfox": true,
    "php": true,
    "react-typescript-snippets": true,
    "snippets": true,
    "sql": true,
    "less": true,
  },
}
